# ─────────────────────────────────────────────────────────────
# LAYOUTNEMO 환경 변수 예시 파일
# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 `.env.local` 로 만든 뒤,
# 아래 값들을 실제 값으로 교체해서 사용하세요.
#
# ⚠️ .env.local 은 .gitignore 에 포함되어 있으므로 절대 커밋되지 않습니다.
#    .env.example 만 Git 에 올라갑니다.
#
# 사용:
#   cp .env.example .env.local
#   # .env.local 열어서 실제 값 입력
# ─────────────────────────────────────────────────────────────


# ── [필수] OpenAI ──
# AI 기반 블럭 생성 / 정리하기 기능 사용 시 필요.
# 값이 없거나 잘못되면 AI 기능만 동작하지 않고, 나머지 UI 는 정상 동작합니다.
#
# 키 발급: https://platform.openai.com/api-keys
# 형식:     sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx...
OPENAI_API_KEY=sk-proj-여기에_본인_키_붙여넣기


# ── [필수, 로그인 기능 사용 시] Supabase ──
# Google OAuth 로그인과 데이터 동기화에 사용.
# 값이 없으면 로그인 UI 는 숨겨지고 로컬 모드로만 동작합니다.
#
# 발급 위치: Supabase Dashboard → 프로젝트 선택 → Settings → API
#
# NEXT_PUBLIC_ prefix 가 붙은 두 값은 클라이언트에 노출되어도 안전한 공개 키입니다.
# (RLS 로 데이터 격리 — 사용자별 접근만 허용)

# Project URL — 형식: https://<프로젝트ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://여기에_프로젝트_URL_붙여넣기.supabase.co

# anon public key — 형식: eyJhbGciOi... (긴 JWT 문자열)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc여기에_anon_key_붙여넣기


# ── [선택, 서버 전용] Supabase Service Role Key ──
# 관리자 작업 / 서버 사이드 트리거 / 마이그레이션 실행 시에만.
# ⚠️ 이 키는 절대 클라이언트로 노출하면 안 됩니다 (RLS 우회 가능).
#    NEXT_PUBLIC_ prefix 붙이지 말 것.
#
# 발급 위치: Settings → API → service_role key (reveal 클릭)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc여기에_service_role_key_붙여넣기
